# Root-level ignores (backend/ and frontend/ have their own .gitignore too)

# OS / Editors
.DS_Store
Thumbs.db
.vscode/
.idea/
.cursor/
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# Node
node_modules/

# Env
.env
.env.local
.env.*.local

# Build output
dist/
build/

# PHP / Laravel
vendor/
backend/.env
backend/storage/*.key
backend/storage/logs/*
backend/storage/framework/cache/data/*
backend/storage/framework/sessions/*
backend/storage/framework/views/*
backend/public/build/
backend/public/hot/
backend/public/storage
backend/database/database.sqlite

# Frontend build
frontend/dist/
frontend/node_modules/
